{
  "name": "neurosymbolic",
  "version": "1.0.2",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "neurosymbolic",
      "version": "1.0.2",
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "dependencies": {
        "application-server": "^1.0.0",
        "process-manager": "^1.0.0"
      }
    },
    "node_modules/application-server": {
      "resolved": "packages/application-server",
      "link": true
    },
    "node_modules/process-manager": {
      "resolved": "packages/process-manager",
      "link": true
    },
    "node_modules/web-framework": {
      "resolved": "packages/web-framework",
      "link": true
    },
    "packages/application-server": {
      "version": "1.0.0",
      "dependencies": {
        "web-framework": "^1.0.0"
      }
    },
    "packages/process-manager": {
      "version": "1.0.0",
      "bin": {
        "pm": "pm.js"
      }
    },
    "packages/web-framework": {
      "version": "1.0.0"
    }
  }
}
